# Server
PORT=3000

# Database (Railway volume path in production; omit to use ./data.db locally)
DB_PATH=./data.db

# Admin password — if set, all checklist mutations and the admin UI require this password.
# Leave blank to disable auth (local development only).
ADMIN_PASSWORD=

# Slack webhook URL for the Battle Stations seeded checklist (optional)
BATTLE_STATIONS_SLACK_WEBHOOK=

# Email for Battle Stations notifications (optional)
BATTLE_STATIONS_EMAIL=

# SMTP — required only if any checklist has a notification_email configured
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
SMTP_FROM=Checklister <noreply@example.com>
